# Docker Compose database settings
POSTGRES_DB=currency_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Use the line below for Docker Compose
DATABASE_URL="postgresql://postgres:password@postgres:5432/currency_tracker"

# Use this instead if you run the server directly on your machine
# DATABASE_URL="postgresql://postgres:password@localhost:5432/currency_tracker"

NODE_ENV=production
PORT=5000
CLIENT_URL=http://localhost:3000

# Min 32 characters
JWT_SECRET=change_this_to_a_long_random_secret_key_32_chars_min
JWT_EXPIRES_IN=7d

# Optional. Leave empty to run without Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

CBU_API_URL=https://cbu.uz/uz/arkhiv-kursov-valyut/json/
SCRAPE_INTERVAL=0 9 * * *

ADMIN_EMAIL=admin@currency.uz
ADMIN_PASSWORD=Admin@12345
