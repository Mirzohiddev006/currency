# Docker Compose database settings
POSTGRES_DB=currency_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password

# Database URL for Docker Compose (internal network)
DATABASE_URL="postgresql://postgres:your_secure_password@postgres:5432/currency_tracker"

NODE_ENV=production
PORT=5000
CLIENT_URL=http://localhost

# Min 32 characters - GENERATE A NEW ONE FOR PRODUCTION!
JWT_SECRET=generate_a_new_random_secret_key_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

CBU_API_URL=https://cbu.uz/uz/arkhiv-kursov-valyut/json/
SCRAPE_INTERVAL=0 9 * * *

# Admin credentials - CHANGE THESE IN PRODUCTION!
ADMIN_EMAIL=admin@currency.uz
ADMIN_PASSWORD=ChangeThisPassword123!
